<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="@dimen/padding_screen">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:text="@string/app_title"
        android:textColor="@color/white"
        android:textSize="@dimen/text_title" />

    <Button
        android:id="@+id/searchButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_weight="1"
        android:backgroundTint="@color/white"
        android:text="@string/search_button"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="@dimen/text_button"
        app:cornerRadius="@dimen/button_corner_radius"
        app:icon="@drawable/search_icon"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/padding_icon"
        app:iconTint="@color/black" />

    <Button
        android:id="@+id/libraryButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_between_buttons"
        android:layout_weight="1"
        android:backgroundTint="@color/white"
        android:text="@string/library_button"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="@dimen/text_button"
        app:cornerRadius="@dimen/button_corner_radius"
        app:icon="@drawable/media_icon"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/padding_icon"
        app:iconTint="@color/black" />

    <Button
        android:id="@+id/settingsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_between_buttons"
        android:layout_weight="1"
        android:backgroundTint="@color/white"
        android:text="@string/settings_button"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="@dimen/text_button"
        app:cornerRadius="@dimen/button_corner_radius"
        app:icon="@drawable/settings_icon"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/padding_icon"
        app:iconTint="@color/black" />

</LinearLayout>
