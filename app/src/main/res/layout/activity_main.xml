<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSecondary"
    android:orientation="vertical"
    android:paddingLeft="@dimen/padding_screen"
    android:paddingTop="14dp"
    android:paddingRight="@dimen/padding_screen"
    android:theme="@style/Theme.PlaylistMaker">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/ys_display_medium"
        android:text="@string/app_title"
        android:textColor="?attr/colorOnSecondary"
        android:textSize="@dimen/text_title" />

    <Button
        android:id="@+id/searchButton"
        style="@style/ButtonStyle"
        android:layout_marginTop="40dp"
        android:text="@string/search_button"
        app:icon="@drawable/ic_search_24" />

    <Button
        android:id="@+id/libraryButton"
        style="@style/ButtonStyle"
        android:layout_marginTop="@dimen/margin_between_buttons"
        android:text="@string/library_button"
        app:icon="@drawable/ic_media_24" />

    <Button
        android:id="@+id/settingsButton"
        style="@style/ButtonStyle"
        android:layout_marginTop="@dimen/margin_between_buttons"
        android:layout_marginBottom="28dp"
        android:text="@string/settings_button"
        app:icon="@drawable/ic_settings_24" />

</LinearLayout>
