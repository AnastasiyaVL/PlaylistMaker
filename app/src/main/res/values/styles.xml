<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TitleToolbarStyle">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
    </style>

    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="backgroundTint">@color/yp_white</item>
        <item name="iconTint">@color/yp_black</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/padding_icon</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textColor">@color/yp_black</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:layout_weight">1</item>
    </style>


    <style name="SettingsMenuItemStyle" parent="Widget.MaterialComponents.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">20dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="drawableTint">?attr/colorControlNormal</item>
    </style>

    <style name="SettingsSwitchStyle" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">20dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="trackTint">@color/switch_track</item>
        <item name="thumbTint">@color/switch_thumb</item>
    </style>

    <style name="PlaceholderTitleStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">19sp</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="NoteBackStyle">
        <item name="android:layout_width">102dp</item>
        <item name="android:layout_height">94dp</item>
        <item name="android:layout_marginStart">9dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:tint">?attr/colorControlNormal</item>
    </style>

    <style name="NoteFrontStyle">
        <item name="android:layout_width">31dp</item>
        <item name="android:layout_height">110dp</item>
        <item name="android:layout_marginStart">80dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:tint">?attr/colorControlNormal</item>
    </style>

    <style name="PlaceholderCenterIconStyle">
        <item name="android:layout_width">69dp</item>
        <item name="android:layout_height">69dp</item>
        <item name="android:layout_marginStart">37dp</item>
        <item name="android:layout_marginTop">28dp</item>
    </style>
</resources>
